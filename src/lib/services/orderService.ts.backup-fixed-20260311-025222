import { neon } from '@neondatabase/serverless';
import { Order } from '@/types/auth';

// Create SQL client with increased timeout for cold starts
const sql = neon(process.env.DATABASE_URL!, {
  fetchOptions: {
    timeout: 30000, // Increase to 30 seconds for cold starts
  }
});

// Connection pool to keep alive
let isConnected = false;

export interface OrderFilters {
  userId?: string;
  status?: string;
  limit?: number;
  orderNumber?: string;
  customerEmail?: string;
  customerPhone?: string;
}

export interface OrdersResponse {
  success: boolean;
  data: Order[];
  total: number;
  error?: string;
}

// Generate unique order number
export function generateOrderNumber(): string {
  const date = new Date();
  const year = date.getFullYear();
  const month = String(date.getMonth() + 1).padStart(2, '0');
  const day = String(date.getDate()).padStart(2, '0');
  const random = Math.floor(Math.random() * 10000).toString().padStart(4, '0');
  return `PA-${year}${month}${day}-${random}`;
}

export class OrderService {
  
  // Helper to handle retries on timeout with exponential backoff
  private async executeWithRetry<T>(queryFn: () => Promise<T>, retries = 3): Promise<T> {
    let lastError: any;
    
    for (let i = 0; i < retries; i++) {
      try {
        // Try to wake up the database on first attempt
        if (i === 0 && !isConnected) {
          console.log('Waking up database...');
        }
        
        return await queryFn();
      } catch (error: any) {
        lastError = error;
        
        // Check if it's a timeout error
        if (error?.code === 'UND_ERR_CONNECT_TIMEOUT' || 
            error?.message?.includes('timeout') ||
            error?.cause?.code === 'UND_ERR_CONNECT_TIMEOUT') {
          
          console.log(`Database timeout (attempt ${i + 1}/${retries}), waiting ${(i + 1) * 2}s...`);
          
          // Exponential backoff: 2s, 4s, 6s
          const waitTime = (i + 1) * 2000;
          await new Promise(resolve => setTimeout(resolve, waitTime));
          
          // Mark as disconnected so next attempt tries to wake it up
          isConnected = false;
          continue;
        }
        
        // If it's not a timeout error, throw immediately
        throw error;
      }
    }
    
    console.error('All retry attempts failed');
    throw lastError;
  }

  // Test connection and keep warm
  async keepWarm(): Promise<boolean> {
    try {
      await this.executeWithRetry(async () => {
        const result = await sql`SELECT 1 as connection_test`;
        isConnected = true;
        return result;
      }, 1);
      return true;
    } catch (error) {
      console.error('Keep warm failed:', error);
      return false;
    }
  }

  // Get orders with filters
  async getOrders(filters: OrderFilters = {}): Promise<OrdersResponse> {
    try {
      // Try to keep connection warm
      await this.keepWarm().catch(() => {});
      
      const query = this.executeWithRetry(async () => {
        let queryText = 'SELECT * FROM "Order"';
        const conditions: string[] = [];
        
        if (filters.userId) {
          conditions.push(`"userId" = '${filters.userId}'`);
        }
        if (filters.status) {
          conditions.push(`status = '${filters.status}'`);
        }
        if (filters.orderNumber) {
          conditions.push(`"orderNumber" = '${filters.orderNumber}'`);
        }
        if (filters.customerEmail) {
          conditions.push(`"customerEmail" = '${filters.customerEmail}'`);
        }
        if (filters.customerPhone) {
          conditions.push(`"customerPhone" = '${filters.customerPhone}'`);
        }

        if (conditions.length > 0) {
          queryText += ' WHERE ' + conditions.join(' AND ');
        }

        queryText += ' ORDER BY "createdAt" DESC';

        if (filters.limit) {
          queryText += ` LIMIT ${filters.limit}`;
        }

        return await sql(queryText);
      });

      const orders = await query;

      // Get total count
      const countResult = await this.executeWithRetry(async () => {
        let countQuery = 'SELECT COUNT(*) FROM "Order"';
        if (filters.userId || filters.status || filters.customerEmail || filters.customerPhone) {
          const countConditions: string[] = [];
          if (filters.userId) countConditions.push(`"userId" = '${filters.userId}'`);
          if (filters.status) countConditions.push(`status = '${filters.status}'`);
          if (filters.customerEmail) countConditions.push(`"customerEmail" = '${filters.customerEmail}'`);
          if (filters.customerPhone) countConditions.push(`"customerPhone" = '${filters.customerPhone}'`);
          countQuery += ' WHERE ' + countConditions.join(' AND ');
        }
        return await sql(countQuery);
      });

      const total = parseInt(countResult[0].count);

      return {
        success: true,
        data: orders as Order[],
        total
      };
    } catch (error) {
      console.error('Error fetching orders:', error);
      return {
        success: false,
        data: [],
        total: 0,
        error: 'Failed to fetch orders'
      };
    }
  }

  // Get single order by ID
  async getOrderById(id: number): Promise<Order | null> {
    try {
      await this.keepWarm().catch(() => {});
      
      const orders = await this.executeWithRetry(
        () => sql`SELECT * FROM "Order" WHERE id = ${id}`
      );
      return orders[0] as Order || null;
    } catch (error) {
      console.error('Error fetching order:', error);
      return null;
    }
  }

  // Create new order with customer data
  async createOrder(orderData: any): Promise<Order | null> {
    try {
      // Ensure database is awake before insert
      await this.keepWarm().catch(() => {});
      
      // Generate order number
      const orderNumber = generateOrderNumber();

      // Get customer information
      const customerName = orderData.customerName || 
                          orderData.shippingAddress?.name || 
                          'Walk-in Customer';
      
      const customerPhone = orderData.customerPhone || 
                           orderData.shippingAddress?.phone || 
                           'N/A';
      
      const customerEmail = orderData.customerEmail || 
                           orderData.userEmail || 
                           '';

      const now = new Date().toISOString();

      console.log('Inserting order with customer data:', {
        orderNumber,
        customerName,
        customerPhone,
        customerEmail
      });

      // Using tagged template for insertion
      const result = await this.executeWithRetry(
        () => sql`
          INSERT INTO "Order" (
            "userId", "orderNumber", items, subtotal, shipping, tax, total,
            status, "shippingAddress", "billingAddress", "paymentMethod",
            "paymentStatus", notes, "createdAt", "updatedAt",
            "customerName", "customerPhone", "customerEmail"
          ) VALUES (
            ${orderData.userId || null},
            ${orderNumber},
            ${JSON.stringify(orderData.items)},
            ${orderData.subtotal || 0},
            ${orderData.shipping || 0},
            ${orderData.tax || 0},
            ${orderData.total || 0},
            ${orderData.status || 'pending'},
            ${orderData.shippingAddress ? JSON.stringify(orderData.shippingAddress) : null},
            ${orderData.billingAddress ? JSON.stringify(orderData.billingAddress) : null},
            ${orderData.paymentMethod || 'pending'},
            'pending',
            ${orderData.notes || ''},
            ${now},
            ${now},
            ${customerName},
            ${customerPhone},
            ${customerEmail}
          ) RETURNING id
        `
      );

      const newOrderId = result[0].id;
      console.log('Order created with ID:', newOrderId);
      
      return await this.getOrderById(newOrderId);
    } catch (error) {
      console.error('Error creating order:', error);
      return null;
    }
  }

  // Update order status
  async updateOrderStatus(orderId: number, status: string, notes?: string): Promise<Order | null> {
    try {
      await this.keepWarm().catch(() => {});
      
      const orders = await this.executeWithRetry(
        () => sql`
          UPDATE "Order" 
          SET status = ${status}, 
              notes = COALESCE(${notes}, notes), 
              "updatedAt" = ${new Date().toISOString()}
          WHERE id = ${orderId}
          RETURNING *
        `
      );
      
      return orders[0] as Order || null;
    } catch (error) {
      console.error('Error updating order:', error);
      return null;
    }
  }

  // Get orders by customer email
  async getOrdersByEmail(email: string): Promise<Order[]> {
    try {
      await this.keepWarm().catch(() => {});
      
      const orders = await this.executeWithRetry(
        () => sql`SELECT * FROM "Order" WHERE "customerEmail" = ${email} ORDER BY "createdAt" DESC`
      );
      return orders as Order[];
    } catch (error) {
      console.error('Error fetching orders by email:', error);
      return [];
    }
  }

  // Get orders by customer phone
  async getOrdersByPhone(phone: string): Promise<Order[]> {
    try {
      await this.keepWarm().catch(() => {});
      
      const orders = await this.executeWithRetry(
        () => sql`SELECT * FROM "Order" WHERE "customerPhone" = ${phone} ORDER BY "createdAt" DESC`
      );
      return orders as Order[];
    } catch (error) {
      console.error('Error fetching orders by phone:', error);
      return [];
    }
  }

  // Get user orders
  async getUserOrders(userId: string): Promise<Order[]> {
    try {
      await this.keepWarm().catch(() => {});
      
      const orders = await this.executeWithRetry(
        () => sql`SELECT * FROM "Order" WHERE "userId" = ${userId} ORDER BY "createdAt" DESC`
      );
      return orders as Order[];
    } catch (error) {
      console.error('Error fetching user orders:', error);
      return [];
    }
  }
}

export const orderService = new OrderService();

// Keep the connection warm with a periodic ping (optional)
if (process.env.NODE_ENV === 'production') {
  setInterval(() => {
    orderService.keepWarm().catch(() => {});
  }, 60000); // Ping every minute
}
