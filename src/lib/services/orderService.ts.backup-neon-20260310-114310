import { neon } from '@neondatabase/serverless';
import { Order } from '@/types/auth';

const sql = neon(process.env.DATABASE_URL!);

export interface OrderFilters {
  userId?: string;
  status?: string;
  limit?: number;
}

export interface OrdersResponse {
  success: boolean;
  data: Order[];
  total: number;
  error?: string;
}

class OrderService {
  async getOrders(filters: OrderFilters = {}): Promise<OrdersResponse> {
    try {
      let query = 'SELECT * FROM "Order"';
      const conditions: string[] = [];
      const values: any[] = [];
      let paramIndex = 1;

      if (filters.userId) {
        conditions.push(`"userId" = $${paramIndex++}`);
        values.push(filters.userId);
      }
      if (filters.status) {
        conditions.push(`status = $${paramIndex++}`);
        values.push(filters.status);
      }

      if (conditions.length > 0) {
        query += ' WHERE ' + conditions.join(' AND ');
      }

      query += ' ORDER BY "createdAt" DESC';

      if (filters.limit) {
        query += ` LIMIT $${paramIndex++}`;
        values.push(filters.limit);
      }

      console.log('Executing SQL:', query, 'with values:', values);
      
      // Execute the query - sql.query returns the rows directly as an array
      const rows = await sql.query(query, values);
      console.log('Query result rows:', rows.length);

      return {
        success: true,
        data: rows as Order[],
        total: rows.length,
      };
    } catch (error) {
      console.error('❌ SQL error in getOrders:', error);
      if (error instanceof Error) {
        console.error('Stack:', error.stack);
      }
      return {
        success: false,
        data: [],
        total: 0,
        error: error instanceof Error ? error.message : 'Unknown error',
      };
    }
  }

  async getUserOrders(userId: string): Promise<Order[]> {
    const response = await this.getOrders({ userId });
    if (!response.success) {
      console.error('Failed to get user orders:', response.error);
      return [];
    }
    return response.data;
  }

  async getOrderById(id: number): Promise<Order | null> {
    try {
      const rows = await sql`SELECT * FROM "Order" WHERE id = ${id}`;
      return (rows[0] as Order) || null;
    } catch (error) {
      console.error('Error in getOrderById:', error);
      return null;
    }
  }

  async updateOrderStatus(id: number, status: string, trackingNumber?: string): Promise<Order | null> {
    try {
      const rows = await sql`
        UPDATE "Order"
        SET status = ${status}, "trackingNumber" = ${trackingNumber ?? null}, "updatedAt" = NOW()
        WHERE id = ${id}
        RETURNING *
      `;
      return (rows[0] as Order) || null;
    } catch (error) {
      console.error('Error in updateOrderStatus:', error);
      return null;
    }
  }

  async createOrder(orderData: any): Promise<Order | null> {
    try {
      const orderNumber = `ORD-${Date.now()}`;
      const rows = await sql`
        INSERT INTO "Order" (
          "userId", "orderNumber", items, subtotal, shipping, tax, total,
          status, "shippingAddress", "billingAddress", "paymentMethod", "paymentStatus",
          "trackingNumber", "estimatedDelivery", "actualDelivery", notes,
          "createdAt", "updatedAt"
        ) VALUES (
          ${orderData.userId}, ${orderNumber}, ${JSON.stringify(orderData.items)},
          ${orderData.subtotal}, ${orderData.shipping}, ${orderData.tax}, ${orderData.total},
          ${orderData.status}, ${orderData.shippingAddress ? JSON.stringify(orderData.shippingAddress) : null},
          ${orderData.billingAddress ? JSON.stringify(orderData.billingAddress) : null},
          ${orderData.paymentMethod}, ${orderData.paymentStatus},
          ${orderData.trackingNumber ?? null}, ${orderData.estimatedDelivery ?? null},
          ${orderData.actualDelivery ?? null}, ${orderData.notes ?? ''},
          NOW(), NOW()
        )
        RETURNING *
      `;
      return (rows[0] as Order) || null;
    } catch (error) {
      console.error('Error in createOrder:', error);
      return null;
    }
  }

  async getOrderStats(): Promise<{ totalOrders: number; totalRevenue: number; byStatus: Record<string, number> }> {
    try {
      const rows = await sql`
        SELECT
          COUNT(*) as total_orders,
          COALESCE(SUM(total), 0) as total_revenue,
          jsonb_object_agg(status, status_count) as by_status
        FROM (
          SELECT status, COUNT(*) as status_count
          FROM "Order"
          GROUP BY status
        ) sub
      `;
      const stats = rows[0] || { total_orders: 0, total_revenue: 0, by_status: {} };
      return {
        totalOrders: parseInt(stats.total_orders),
        totalRevenue: parseFloat(stats.total_revenue),
        byStatus: stats.by_status || {},
      };
    } catch (error) {
      console.error('Error in getOrderStats:', error);
      return { totalOrders: 0, totalRevenue: 0, byStatus: {} };
    }
  }
}

export const orderService = new OrderService();
