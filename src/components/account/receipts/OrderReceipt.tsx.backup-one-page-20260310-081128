Write-Host "=== UPDATING ORDER RECEIPT TO STANDARD FORMAT ===" -ForegroundColor Cyan

$receiptPath = "src/components/account/receipts/OrderReceipt.tsx"

$standardReceipt = @'
'use client';

import React, { useEffect } from 'react';
import { Order } from '@/types/auth';
import QRCode from 'qrcode';

interface OrderReceiptProps {
  order: Order;
  onClose: () => void;
}

const OrderReceipt: React.FC<OrderReceiptProps> = ({ order, onClose }) => {
  useEffect(() => {
    generateReceiptWindow();
  }, []);

  const formatDate = (date: string | Date) => {
    if (!date) return 'N/A';
    const dateObj = typeof date === 'string' ? new Date(date) : date;
    return dateObj.toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    });
  };

  const numberToWords = (num: number): string => {
    const ones = ['', 'One', 'Two', 'Three', 'Four', 'Five', 'Six', 'Seven', 'Eight', 'Nine'];
    const tens = ['', '', 'Twenty', 'Thirty', 'Forty', 'Fifty', 'Sixty', 'Seventy', 'Eighty', 'Ninety'];
    const teens = ['Ten', 'Eleven', 'Twelve', 'Thirteen', 'Fourteen', 'Fifteen', 'Sixteen', 'Seventeen', 'Eighteen', 'Nineteen'];

    const convertLessThanThousand = (n: number): string => {
      if (n === 0) return '';
      
      let result = '';
      
      if (n >= 100) {
        result += ones[Math.floor(n / 100)] + ' Hundred ';
        n %= 100;
      }
      
      if (n >= 20) {
        result += tens[Math.floor(n / 20)] + ' ';
        n %= 20;
      } else if (n >= 10) {
        result += teens[n - 10] + ' ';
        n = 0;
      }
      
      if (n > 0) {
        result += ones[n] + ' ';
      }
      
      return result;
    };

    if (num === 0) return 'Zero';

    let words = '';
    let n = Math.floor(num);
    
    if (n >= 1000000) {
      words += convertLessThanThousand(Math.floor(n / 1000000)) + 'Million ';
      n %= 1000000;
    }
    
    if (n >= 1000) {
      words += convertLessThanThousand(Math.floor(n / 1000)) + 'Thousand ';
      n %= 1000;
    }
    
    words += convertLessThanThousand(n);
    
    return words.trim() + ' Naira Only';
  };

  const generateReceiptWindow = async () => {
    // Calculate installation items and fee
    const installationKeywords = ['inverter', 'solar panel', 'battery', 'generator', 'system', 'complete kit', 'off-grid'];
    const installationItems = order.items.filter((item: any) => {
      const title = item.title?.toLowerCase() || '';
      return installationKeywords.some(keyword => title.includes(keyword));
    });
    
    const installationFee = installationItems.reduce((sum, item) => {
      return sum + (item.price * item.quantity * 0.1);
    }, 0);

    const subtotal = order.subtotal || order.total;
    const totalWithInstallation = subtotal + installationFee;

    // Generate QR Code
    let qrCodeUrl = '';
    try {
      const verificationData = {
        orderId: order.id,
        orderNumber: order.orderNumber,
        date: order.createdAt,
        total: totalWithInstallation,
        status: order.status,
        installationFee: installationFee
      };
      qrCodeUrl = await QRCode.toDataURL(JSON.stringify(verificationData), {
        width: 120,
        margin: 1,
        color: {
          dark: '#1a2a8a',
          light: '#FFFFFF'
        }
      });
    } catch (err) {
      console.error('Error generating QR code:', err);
    }

    const receiptHTML = `
      <!DOCTYPE html>
      <html lang="en">
      <head>
        <meta charset="UTF-8">
        <title>Power Afric Energy Services Receipt - Order #${order.orderNumber || order.id}</title>
        <style>
          @page {
            size: A4;
            margin: 0;
          }

          * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
          }

          body {
            margin: 0;
            background: #e5e7eb;
            padding: 20px;
            font-family: 'Arial', sans-serif;
          }

          /* A4 SHEET */
          .a4 {
            width: 210mm;
            min-height: 297mm;
            position: relative;
            margin: 0 auto;
            background: white;
            overflow: hidden;
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
          }

          /* LOGO REPEAT PATTERN */
          .logo-pattern {
            position: absolute;
            inset: 0;
            background-image: url("https://res.cloudinary.com/djkudkxmx/image/upload/v1762182244/logo-blue_yns0bj.png");
            background-size: 60px auto;
            background-position: 0 0;
            background-repeat: repeat;
            opacity: 0.08;
          }

          /* GRADIENT BORDER WRAPPER */
          .inner-paper-wrapper {
            position: absolute;
            width: 94%;
            height: 96%;
            top: 2%;
            left: 3%;
            border-radius: 20px;
            background: linear-gradient(to right, #07A500, #3E4095);
            padding: 6px;
          }

          /* INNER PAPER */
          .inner-paper {
            width: 100%;
            height: 100%;
            border-radius: 15px;
            background: rgba(255, 255, 255, 0.98);
            padding: 2rem;
            box-sizing: border-box;
            overflow-y: auto;
          }

          /* Company Header */
          .company-header {
            display: flex;
            align-items: flex-start;
            gap: 1rem;
            margin-bottom: 1.5rem;
          }

          .company-title {
            font-size: 22px;
            font-weight: bold;
            color: #1a2a8a;
          }

          .company-address, .company-contact {
            font-size: 10px;
            color: #4b5563;
            line-height: 1.4;
          }

          /* Cash Receipt Title */
          .cash-receipt-title {
            background: linear-gradient(to right, #07A500, #3E4095);
            color: white;
            font-weight: bold;
            padding: 0.5rem 1.5rem;
            border-radius: 5px;
            display: inline-block;
          }

          /* Receipt fields styling */
          .receipt-line {
            border-bottom: 1px solid #9ca3af;
            min-height: 1.8rem;
            margin-bottom: 0.5rem;
          }

          .checkbox-group {
            display: flex;
            gap: 1.5rem;
            margin: 0.5rem 0;
          }

          .checkbox-item {
            display: flex;
            align-items: center;
            gap: 0.25rem;
          }

          table {
            width: 100%;
            border-collapse: collapse;
            font-size: 11px;
            margin: 0.75rem 0;
          }

          th, td {
            border: 1px solid #d1d5db;
            padding: 0.5rem;
            text-align: left;
          }

          th {
            background: #f3f4f6;
            font-weight: 600;
          }

          .installation-badge {
            background: #dbeafe;
            color: #1e40af;
            font-size: 9px;
            padding: 0.15rem 0.5rem;
            border-radius: 9999px;
            margin-left: 0.5rem;
          }

          .installation-row {
            background: #eff6ff;
          }

          .total-row {
            font-weight: bold;
            font-size: 14px;
          }

          .grand-total {
            color: #1a2a8a;
            font-size: 16px;
            font-weight: bold;
          }

          .installation-summary {
            background: #eff6ff;
            border-left: 4px solid #3e4095;
            padding: 1rem;
            border-radius: 0.5rem;
            margin: 1rem 0;
          }

          .footer {
            margin-top: 2rem;
            text-align: center;
            font-size: 9px;
            color: #6b7280;
            border-top: 1px solid #e5e7eb;
            padding-top: 1rem;
          }

          @media print {
            body {
              background: white;
              padding: 0;
            }
            .no-print {
              display: none;
            }
          }
        </style>
      </head>
      <body>
        <div class="no-print" style="text-align: center; margin-bottom: 20px;">
          <button onclick="window.print()" style="padding: 12px 24px; background: #1a2a8a; color: white; border: none; border-radius: 8px; cursor: pointer; margin-right: 10px; font-size: 14px;">
            🖨️ Print Receipt
          </button>
          <button onclick="window.close()" style="padding: 12px 24px; background: #6b7280; color: white; border: none; border-radius: 8px; cursor: pointer; font-size: 14px;">
            ✕ Close
          </button>
        </div>

        <div class="a4">
          <div class="logo-pattern"></div>

          <div class="inner-paper-wrapper">
            <div class="inner-paper">
              <!-- Company Header -->
              <div class="company-header">
                <img src="https://res.cloudinary.com/djkudkxmx/image/upload/v1762182244/logo-blue_yns0bj.png" alt="Logo" style="width: 70px; height: auto;">
                <div>
                  <div class="company-title">POWER AFRIC ENERGY SERVICES LTD</div>
                  <div class="company-address">No. B3 & B4 Khalil Rahman Shopping Complex, GRA. Katsina State - Nigeria.</div>
                  <div class="company-contact">08033666041 • 08100360057 • sales@powerafric.ng • www.powerafric.ng</div>
                </div>
              </div>

              <!-- Cash Receipt Title & Number -->
              <div style="display: flex; justify-content: space-between; align-items: center; margin: 1.5rem 0 1rem 0;">
                <div class="cash-receipt-title">CASH RECEIPT</div>
                <div class="font-semibold text-gray-700" style="font-size: 12px;">
                  Receipt No.: PAE/FDCR/${order.orderNumber || order.id}/${new Date(order.createdAt).getFullYear()}
                </div>
              </div>

              <!-- Customer Information -->
              <div style="margin-bottom: 1.5rem;">
                <div style="margin-bottom: 0.75rem;">
                  <p style="font-weight: bold; font-size: 12px; margin-bottom: 0.25rem;">Name:</p>
                  <div class="receipt-line" style="padding-left: 0.5rem;">${order.shippingAddress?.fullName || order.user?.fullName || order.customerName || 'N/A'}</div>
                </div>

                <div style="margin-bottom: 0.75rem;">
                  <p style="font-weight: bold; font-size: 12px; margin-bottom: 0.25rem;">Address:</p>
                  <div class="receipt-line" style="padding-left: 0.5rem;">${order.shippingAddress ? `${order.shippingAddress.street || ''}, ${order.shippingAddress.city || ''}, ${order.shippingAddress.state || ''}` : 'N/A'}</div>
                </div>

                <div style="margin-bottom: 0.75rem;">
                  <p style="font-weight: bold; font-size: 12px; margin-bottom: 0.25rem;">Phone:</p>
                  <div class="receipt-line" style="padding-left: 0.5rem;">${order.shippingAddress?.phone || order.user?.phone || order.customerPhone || 'N/A'}</div>
                </div>
              </div>

              <!-- Items Table -->
              <div style="margin-bottom: 1.5rem;">
                <h3 style="font-weight: bold; font-size: 13px; margin-bottom: 0.5rem;">Items Purchased:</h3>
                <table>
                  <thead>
                    <tr>
                      <th>Item</th>
                      <th style="width: 60px;">Qty</th>
                      <th style="width: 100px;">Unit Price</th>
                      <th style="width: 80px;">Installation</th>
                      <th style="width: 100px;">Total</th>
                    </tr>
                  </thead>
                  <tbody>
                    ${order.items.map((item: any) => {
                      const needsInstallation = installationItems.some(i => i.id === item.id);
                      const itemTotal = item.price * item.quantity;
                      return `
                        <tr ${needsInstallation ? 'class="installation-row"' : ''}>
                          <td>
                            ${item.title}
                            ${needsInstallation ? '<span class="installation-badge">Installation Required</span>' : ''}
                          </td>
                          <td style="text-align: center;">${item.quantity}</td>
                          <td style="text-align: right;">₦${item.price.toLocaleString()}</td>
                          <td style="text-align: center;">${needsInstallation ? '10%' : '-'}</td>
                          <td style="text-align: right;">₦${itemTotal.toLocaleString()}</td>
                        </tr>
                      `;
                    }).join('')}
                    
                    ${installationFee > 0 ? `
                      <tr class="installation-row">
                        <td colspan="4" style="text-align: right; font-weight: bold;">Installation Services Fee (10%):</td>
                        <td style="text-align: right; font-weight: bold;">₦${installationFee.toLocaleString()}</td>
                      </tr>
                    ` : ''}
                  </tbody>
                  <tfoot>
                    <tr>
                      <td colspan="4" style="text-align: right; font-weight: bold;">Subtotal (Items):</td>
                      <td style="text-align: right;">₦${subtotal.toLocaleString()}</td>
                    </tr>
                    ${installationFee > 0 ? `
                      <tr>
                        <td colspan="4" style="text-align: right; font-weight: bold;">Installation Fee:</td>
                        <td style="text-align: right;">₦${installationFee.toLocaleString()}</td>
                      </tr>
                    ` : ''}
                    ${order.shipping > 0 ? `
                      <tr>
                        <td colspan="4" style="text-align: right; font-weight: bold;">Shipping:</td>
                        <td style="text-align: right;">₦${order.shipping.toLocaleString()}</td>
                      </tr>
                    ` : ''}
                    ${order.tax > 0 ? `
                      <tr>
                        <td colspan="4" style="text-align: right; font-weight: bold;">Tax (VAT):</td>
                        <td style="text-align: right;">₦${order.tax.toLocaleString()}</td>
                      </tr>
                    ` : ''}
                    <tr class="total-row">
                      <td colspan="4" style="text-align: right; font-weight: bold; font-size: 14px;">GRAND TOTAL:</td>
                      <td class="grand-total" style="text-align: right;">₦${totalWithInstallation.toLocaleString()}</td>
                    </tr>
                  </tfoot>
                </table>
              </div>

              <!-- Installation Summary -->
              ${installationItems.length > 0 ? `
                <div class="installation-summary">
                  <h4 style="font-weight: bold; color: #1e40af; margin-bottom: 0.5rem;">📋 Installation Summary</h4>
                  <p style="font-size: 11px; color: #374151; margin-bottom: 0.5rem;">
                    The following items require professional installation (10% fee applies):
                  </p>
                  <ul style="list-style: disc; padding-left: 1.5rem; font-size: 11px; color: #374151;">
                    ${installationItems.map(item => `
                      <li>${item.title} (Qty: ${item.quantity}) - Installation Fee: ₦${(item.price * item.quantity * 0.1).toLocaleString()}</li>
                    `).join('')}
                  </ul>
                  <p style="font-size: 11px; color: #374151; margin-top: 0.5rem;">
                    <strong>Note:</strong> Installation will be scheduled within 3-5 business days after delivery.
                  </p>
                </div>
              ` : ''}

              <!-- Amount Received Section -->
              <div style="margin-top: 1.5rem;">
                <p style="font-weight: bold; font-size: 12px;">Amount Received: ₦${totalWithInstallation.toLocaleString()}</p>
                <div class="receipt-line"></div>
                
                <p style="font-weight: bold; font-size: 12px; margin-top: 0.5rem;">(In Words):</p>
                <div class="receipt-line" style="font-style: italic;">${numberToWords(totalWithInstallation)}</div>

                <p style="font-weight: bold; font-size: 12px; margin-top: 0.5rem;">Payment Purpose / Description:</p>
                <div class="receipt-line">Purchase of Solar Equipment</div>

                <p style="font-weight: bold; font-size: 12px; margin-top: 0.5rem;">Payment Method:</p>
                <div class="checkbox-group">
                  <div class="checkbox-item">
                    <input type="checkbox" ${order.paymentMethod === 'cash' ? 'checked' : ''} disabled> Cash
                  </div>
                  <div class="checkbox-item">
                    <input type="checkbox" ${order.paymentMethod === 'bank_transfer' ? 'checked' : ''} disabled> Bank Transfer
                  </div>
                  <div class="checkbox-item">
                    <input type="checkbox" ${order.paymentMethod === 'cheque' ? 'checked' : ''} disabled> Cheque
                  </div>
                  <div class="checkbox-item">
                    <input type="checkbox" ${order.paymentMethod === 'card' || order.paymentMethod === 'pos' ? 'checked' : ''} disabled> Card / POS
                  </div>
                </div>
              </div>

              <!-- Received By Section -->
              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-top: 1.5rem;">
                <div>
                  <p style="font-weight: bold; font-size: 12px;">Received By:</p>
                  <div class="receipt-line" style="min-height: 2rem;"></div>
                  <div class="receipt-line" style="min-height: 1.5rem;"></div>
                </div>
                <div>
                  <p style="font-weight: bold; font-size: 12px;">Authorized Signature:</p>
                  <div class="receipt-line" style="min-height: 2rem;"></div>
                </div>
              </div>

              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-top: 0.5rem;">
                <div>
                  <p style="font-weight: bold; font-size: 12px;">Name:</p>
                  <p style="font-size: 12px;">Power Afric Sales Team</p>
                </div>
                <div>
                  <p style="font-weight: bold; font-size: 12px;">Date:</p>
                  <p style="font-size: 12px;">${formatDate(order.createdAt)}</p>
                </div>
              </div>

              <!-- QR Code and Verification -->
              <div style="display: flex; justify-content: space-between; align-items: flex-end; margin-top: 2rem;">
                <div style="font-size: 10px; color: #6b7280;">
                  <p>This is a computer-generated receipt. No signature required.</p>
                  <p>For verification, scan the QR code or visit www.powerafric.ng/verify</p>
                  ${installationFee > 0 ? '<p style="color: #1e40af; margin-top: 0.25rem;">✓ Installation fee included in total</p>' : ''}
                </div>
                ${qrCodeUrl ? `
                  <div style="text-align: center;">
                    <img src="${qrCodeUrl}" alt="QR Code" style="width: 70px; height: 70px;" />
                    <p style="font-size: 8px; color: #6b7280; margin-top: 0.25rem;">Scan to verify</p>
                  </div>
                ` : ''}
              </div>

              <!-- Footer -->
              <div class="footer">
                <p>Thank you for choosing Power Afric Energy Services Ltd. We power your world with sustainable energy.</p>
                ${installationFee > 0 ? '<p style="color: #1e40af; margin-top: 0.25rem;">🔧 Professional installation included with your purchase</p>' : ''}
              </div>
            </div>
          </div>
        </div>
      </body>
      </html>
    `;

    const receiptWindow = window.open('', '_blank', 'width=900,height=700,scrollbars=yes,toolbar=yes,menubar=yes,location=yes');
    if (receiptWindow) {
      receiptWindow.document.write(receiptHTML);
      receiptWindow.document.close();
      receiptWindow.focus();
    } else {
      alert('Please allow pop-ups to view the receipt');
    }

    onClose();
  };

  return (
    <div className="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/50 backdrop-blur-sm">
      <div className="bg-white rounded-2xl shadow-2xl p-8 max-w-md text-center">
        <div className="animate-spin rounded-full h-12 w-12 border-b-2 border-[#1a2a8a] mx-auto mb-4"></div>
        <h3 className="text-xl font-bold text-gray-900 mb-2">Opening Receipt</h3>
        <p className="text-gray-600 mb-4">Your receipt is opening in a new window...</p>
        <p className="text-sm text-gray-500">If the window doesn't open, please check your pop-up blocker.</p>
        <button
          onClick={onClose}
          className="mt-6 px-6 py-2 bg-gray-500 text-white rounded-lg hover:bg-gray-600 transition-colors"
        >
          Cancel
        </button>
      </div>
    </div>
  );
};

export default OrderReceipt;
'@

$standardReceipt | Out-File -FilePath $receiptPath -Encoding utf8 -Force

Write-Host "✅ Updated OrderReceipt to standard format" -ForegroundColor Green
Write-Host ""
Write-Host "Features included:" -ForegroundColor Yellow
Write-Host "  - Company logo and branding" -ForegroundColor Gray
Write-Host "  - Gradient border wrapper" -ForegroundColor Gray
Write-Host "  - Receipt number and date" -ForegroundColor Gray
Write-Host "  - Customer information fields" -ForegroundColor Gray
Write-Host "  - Items table with installation fee calculation (10%)" -ForegroundColor Gray
Write-Host "  - Amount in words conversion" -ForegroundColor Gray
Write-Host "  - Payment method checkboxes" -ForegroundColor Gray
Write-Host "  - Received by and signature sections" -ForegroundColor Gray
Write-Host "  - QR code for verification" -ForegroundColor Gray
Write-Host "  - Professional footer" -ForegroundColor Gray
Write-Host ""
Write-Host "Refresh your browser and test the receipt." -ForegroundColor Cyan