'use client';

import React, { useRef, useState, useEffect } from 'react';
import { Order } from '@/types/auth';
import html2canvas from 'html2canvas';
import jsPDF from 'jspdf';
import QRCode from 'qrcode';

interface OrderReceiptProps {
  order: Order;
  onClose: () => void;
}

const OrderReceipt: React.FC<OrderReceiptProps> = ({ order, onClose }) => {
  const receiptRef = useRef<HTMLDivElement>(null);
  const [qrCodeDataUrl, setQrCodeDataUrl] = useState<string>('');
  const [installationItems, setInstallationItems] = useState<any[]>([]);
  const [installationFee, setInstallationFee] = useState<number>(0);

  // Calculate installation fee and identify items needing installation
  useEffect(() => {
    // Identify items that need installation (you can customize this logic)
    const itemsNeedingInstallation = order.items.filter((item: any) => {
      // Check if item title contains installation-related keywords
      const installationKeywords = ['inverter', 'solar panel', 'battery', 'generator', 'system', 'complete kit'];
      const title = item.title?.toLowerCase() || '';
      return installationKeywords.some(keyword => title.includes(keyword));
    });
    
    setInstallationItems(itemsNeedingInstallation);
    
    // Calculate installation fee (e.g., 10% of subtotal for items needing installation)
    const installationCost = itemsNeedingInstallation.reduce((sum, item) => {
      return sum + (item.price * item.quantity * 0.1); // 10% installation fee
    }, 0);
    
    setInstallationFee(installationCost);
  }, [order]);

  // Generate QR code
  useEffect(() => {
    const generateQR = async () => {
      try {
        const verificationData = {
          orderId: order.id,
          orderNumber: order.orderNumber,
          date: order.createdAt,
          total: order.total,
          status: order.status,
          installationFee: installationFee
        };
        
        const url = await QRCode.toDataURL(JSON.stringify(verificationData), {
          width: 120,
          margin: 1,
          color: {
            dark: '#1a2a8a',
            light: '#FFFFFF'
          }
        });
        setQrCodeDataUrl(url);
      } catch (err) {
        console.error('Error generating QR code:', err);
      }
    };
    
    generateQR();
  }, [order, installationFee]);

  const formatDate = (date: string | Date) => {
    if (!date) return 'N/A';
    const dateObj = typeof date === 'string' ? new Date(date) : date;
    return dateObj.toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    });
  };

  const numberToWords = (num: number): string => {
    const ones = ['', 'One', 'Two', 'Three', 'Four', 'Five', 'Six', 'Seven', 'Eight', 'Nine'];
    const tens = ['', '', 'Twenty', 'Thirty', 'Forty', 'Fifty', 'Sixty', 'Seventy', 'Eighty', 'Ninety'];
    const teens = ['Ten', 'Eleven', 'Twelve', 'Thirteen', 'Fourteen', 'Fifteen', 'Sixteen', 'Seventeen', 'Eighteen', 'Nineteen'];

    const convertLessThanThousand = (n: number): string => {
      if (n === 0) return '';
      
      let result = '';
      
      if (n >= 100) {
        result += ones[Math.floor(n / 100)] + ' Hundred ';
        n %= 100;
      }
      
      if (n >= 20) {
        result += tens[Math.floor(n / 20)] + ' ';
        n %= 20;
      } else if (n >= 10) {
        result += teens[n - 10] + ' ';
        n = 0;
      }
      
      if (n > 0) {
        result += ones[n] + ' ';
      }
      
      return result;
    };

    if (num === 0) return 'Zero';

    let words = '';
    let n = Math.floor(num);
    
    if (n >= 1000000) {
      words += convertLessThanThousand(Math.floor(n / 1000000)) + 'Million ';
      n %= 1000000;
    }
    
    if (n >= 1000) {
      words += convertLessThanThousand(Math.floor(n / 1000)) + 'Thousand ';
      n %= 1000;
    }
    
    words += convertLessThanThousand(n);
    
    return words.trim() + ' Naira Only';
  };

  const handleDownloadPDF = async () => {
    if (!receiptRef.current) return;

    try {
      const canvas = await html2canvas(receiptRef.current, {
        scale: 2,
        backgroundColor: '#ffffff',
        logging: false,
        allowTaint: true,
        useCORS: true
      });

      const imgData = canvas.toDataURL('image/png');
      const pdf = new jsPDF({
        orientation: 'portrait',
        unit: 'mm',
        format: 'a4'
      });

      const pdfWidth = pdf.internal.pageSize.getWidth();
      const pdfHeight = pdf.internal.pageSize.getHeight();
      const imgWidth = canvas.width;
      const imgHeight = canvas.height;
      const ratio = Math.min(pdfWidth / imgWidth, pdfHeight / imgHeight);
      const width = imgWidth * ratio;
      const height = imgHeight * ratio;

      pdf.addImage(imgData, 'PNG', (pdfWidth - width) / 2, 0, width, height);
      pdf.save(`receipt-${order.orderNumber || order.id}.pdf`);
    } catch (error) {
      console.error('Error generating PDF:', error);
    }
  };

  const subtotal = order.subtotal || order.total;
  const totalWithInstallation = subtotal + installationFee;

  return (
    <div className="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/50 backdrop-blur-sm overflow-y-auto">
      <div className="relative max-w-4xl w-full">
        {/* Close and Download buttons */}
        <div className="flex justify-end gap-2 mb-4 sticky top-0 z-10">
          <button
            onClick={handleDownloadPDF}
            className="px-4 py-2 bg-[#1a2a8a] text-white rounded-lg hover:bg-[#0f1a66] transition-colors flex items-center shadow-lg"
          >
            <svg className="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
            Download PDF
          </button>
          <button
            onClick={onClose}
            className="px-4 py-2 bg-gray-500 text-white rounded-lg hover:bg-gray-600 transition-colors shadow-lg"
          >
            Close
          </button>
        </div>

        {/* A4 Receipt */}
        <div ref={receiptRef} className="a4 relative mx-auto" style={{ 
          width: '210mm', 
          minHeight: '297mm', 
          background: 'white',
          boxShadow: '0 10px 25px rgba(0,0,0,0.2)',
          position: 'relative',
          overflow: 'hidden'
        }}>
          {/* Logo Pattern Background */}
          <div className="logo-pattern absolute inset-0 opacity-10" style={{
            backgroundImage: 'url("https://res.cloudinary.com/djkudkxmx/image/upload/v1762182244/logo-blue_yns0bj.png")',
            backgroundSize: '60px auto',
            backgroundRepeat: 'repeat'
          }}></div>

          {/* Gradient Border Wrapper */}
          <div className="inner-paper-wrapper absolute" style={{
            width: '90%',
            height: '95%',
            top: '50%',
            left: '50%',
            transform: 'translate(-50%, -50%)',
            borderRadius: '20px',
            position: 'absolute'
          }}>
            {/* Gradient Border using pseudo-element in React style */}
            <div className="absolute inset-0 rounded-2xl" style={{
              padding: '15px',
              background: 'linear-gradient(to right, #07A500, #3E4095)',
              mask: 'linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0)',
              maskComposite: 'exclude',
              WebkitMask: 'linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0)',
              WebkitMaskComposite: 'xor',
              pointerEvents: 'none'
            }}></div>

            {/* Inner Paper */}
            <div className="inner-paper relative" style={{
              left: '2%',
              top: '1.6%',
              width: '96%',
              height: '97.5%',
              borderRadius: '20px',
              background: 'rgba(255, 255, 255, 0.96)',
              padding: '2rem',
              boxSizing: 'border-box',
              zIndex: 1,
              overflowY: 'auto'
            }}>
              {/* Company Header */}
              <div className="company-header flex items-start gap-4 mb-6">
                <img 
                  src="https://res.cloudinary.com/djkudkxmx/image/upload/v1762182244/logo-blue_yns0bj.png" 
                  alt="Power Afric Logo" 
                  className="w-20 h-auto"
                />
                <div className="company-info">
                  <div className="company-title text-xl font-bold text-gray-900">POWER AFRIC ENERGY SERVICES LTD</div>
                  <div className="company-address text-xs text-gray-600 mt-1">No. B3 & B4 Khalil Rahman Shopping Complex, GRA. Katsina State - Nigeria.</div>
                  <div className="company-contact text-xs text-gray-600 mt-1">08033666041 • 08100360057 • sales@powerafric.ng • www.powerafric.ng</div>
                </div>
              </div>

              {/* Cash Receipt Title & Number */}
              <div className="flex justify-between items-center mt-4 mb-6">
                <div className="cash-receipt-title bg-gradient-to-r from-[#07A500] to-[#3E4095] text-white font-bold px-6 py-2 rounded">
                  CASH RECEIPT
                </div>
                <div className="font-semibold text-gray-700">
                  Receipt No.: PAE/FDCR/{order.orderNumber || order.id}/{new Date(order.createdAt).getFullYear()}
                </div>
              </div>

              {/* Customer Information */}
              <div className="receipt-section space-y-4 mb-6">
                <div>
                  <p className="font-bold text-gray-700">Name:</p>
                  <div className="receipt-line border-b border-gray-400 pb-1">
                    {order.shippingAddress?.fullName || 'N/A'}
                  </div>
                </div>

                <div>
                  <p className="font-bold text-gray-700">Address:</p>
                  <div className="receipt-line border-b border-gray-400 pb-1">
                    {order.shippingAddress ? 
                      `${order.shippingAddress.street || ''}, ${order.shippingAddress.city || ''}, ${order.shippingAddress.state || ''}` : 
                      'N/A'}
                  </div>
                </div>

                <div>
                  <p className="font-bold text-gray-700">Phone:</p>
                  <div className="receipt-line border-b border-gray-400 pb-1">
                    {order.shippingAddress?.phone || 'N/A'}
                  </div>
                </div>
              </div>

              {/* Items Table */}
              <div className="mb-6">
                <h3 className="font-bold text-gray-700 mb-2">Items Purchased:</h3>
                <table className="w-full border-collapse text-sm">
                  <thead>
                    <tr className="bg-gray-100">
                      <th className="border p-2 text-left">Item</th>
                      <th className="border p-2 text-left">Qty</th>
                      <th className="border p-2 text-left">Unit Price</th>
                      <th className="border p-2 text-left">Installation</th>
                      <th className="border p-2 text-left">Total</th>
                    </tr>
                  </thead>
                  <tbody>
                    {order.items.map((item: any, index: number) => {
                      const needsInstallation = installationItems.some(i => i.id === item.id);
                      const itemTotal = item.price * item.quantity;
                      
                      return (
                        <tr key={index}>
                          <td className="border p-2">
                            {item.title}
                            {needsInstallation && (
                              <span className="ml-2 text-xs bg-blue-100 text-blue-800 px-2 py-0.5 rounded">
                                Installation Required
                              </span>
                            )}
                          </td>
                          <td className="border p-2 text-center">{item.quantity}</td>
                          <td className="border p-2">₦{item.price.toLocaleString()}</td>
                          <td className="border p-2">
                            {needsInstallation ? (
                              <span className="text-blue-600">10%</span>
                            ) : (
                              <span className="text-gray-400">-</span>
                            )}
                          </td>
                          <td className="border p-2">₦{itemTotal.toLocaleString()}</td>
                        </tr>
                      );
                    })}
                    
                    {/* Installation Fee Row */}
                    {installationFee > 0 && (
                      <tr className="bg-blue-50">
                        <td colSpan={4} className="border p-2 text-right font-bold text-blue-800">
                          Installation Services Fee (10%):
                        </td>
                        <td className="border p-2 font-bold text-blue-800">
                          ₦{installationFee.toLocaleString()}
                        </td>
                      </tr>
                    )}
                  </tbody>
                  <tfoot>
                    <tr>
                      <td colSpan={4} className="border p-2 text-right font-bold">Subtotal (Items):</td>
                      <td className="border p-2">₦{subtotal.toLocaleString()}</td>
                    </tr>
                    {installationFee > 0 && (
                      <tr>
                        <td colSpan={4} className="border p-2 text-right font-bold text-blue-800">
                          Installation Fee:
                        </td>
                        <td className="border p-2 text-blue-800">₦{installationFee.toLocaleString()}</td>
                      </tr>
                    )}
                    {order.shipping > 0 && (
                      <tr>
                        <td colSpan={4} className="border p-2 text-right font-bold">Shipping:</td>
                        <td className="border p-2">₦{order.shipping.toLocaleString()}</td>
                      </tr>
                    )}
                    {order.tax > 0 && (
                      <tr>
                        <td colSpan={4} className="border p-2 text-right font-bold">Tax:</td>
                        <td className="border p-2">₦{order.tax.toLocaleString()}</td>
                      </tr>
                    )}
                    <tr>
                      <td colSpan={4} className="border p-2 text-right font-bold text-lg">GRAND TOTAL:</td>
                      <td className="border p-2 font-bold text-lg text-[#1a2a8a]">₦{totalWithInstallation.toLocaleString()}</td>
                    </tr>
                  </tfoot>
                </table>
              </div>

              {/* Installation Summary */}
              {installationItems.length > 0 && (
                <div className="mb-6 p-4 bg-blue-50 rounded-lg">
                  <h4 className="font-bold text-blue-800 mb-2">📋 Installation Summary</h4>
                  <p className="text-sm text-gray-700 mb-2">
                    The following items require professional installation (10% fee applies):
                  </p>
                  <ul className="list-disc list-inside text-sm text-gray-700">
                    {installationItems.map((item, idx) => (
                      <li key={idx}>
                        {item.title} (Qty: {item.quantity}) - ₦{(item.price * item.quantity * 0.1).toLocaleString()} installation fee
                      </li>
                    ))}
                  </ul>
                  <p className="text-sm text-gray-700 mt-2">
                    <strong>Note:</strong> Installation will be scheduled within 3-5 business days after delivery.
                  </p>
                </div>
              )}

              {/* Amount Received Section */}
              <div className="receipt-section mb-6">
                <p><strong>Amount Received:</strong> ₦{totalWithInstallation.toLocaleString()}</p>
                <div className="receipt-line border-b border-gray-400 mt-2 mb-4"></div>
                
                <p><strong>(In Words):</strong></p>
                <div className="receipt-line border-b border-gray-400 pb-1 italic mb-4">
                  {numberToWords(totalWithInstallation)}
                </div>

                <p><strong>Payment Purpose / Description:</strong> Purchase of Solar Equipment</p>
                <div className="receipt-line border-b border-gray-400 mt-2 mb-4"></div>

                <p><strong>Payment Method:</strong></p>
                <div className="flex flex-wrap gap-4 mt-2 mb-4">
                  <label className="checkbox flex items-center">
                    <input type="checkbox" checked={order.paymentMethod === 'cash'} readOnly className="mr-2" /> Cash
                  </label>
                  <label className="checkbox flex items-center">
                    <input type="checkbox" checked={order.paymentMethod === 'bank_transfer'} readOnly className="mr-2" /> Bank Transfer
                  </label>
                  <label className="checkbox flex items-center">
                    <input type="checkbox" checked={order.paymentMethod === 'cheque'} readOnly className="mr-2" /> Cheque
                  </label>
                  <label className="checkbox flex items-center">
                    <input type="checkbox" checked={order.paymentMethod === 'pos'} readOnly className="mr-2" /> POS
                  </label>
                </div>
              </div>

              {/* Received By Section */}
              <div className="grid grid-cols-2 gap-8 mb-6">
                <div>
                  <p><strong>Received By:</strong></p>
                  <div className="receipt-line border-b border-gray-400 mt-2 mb-4"></div>
                  <div className="receipt-line border-b border-gray-400"></div>
                </div>
                <div>
                  <p><strong>Authorized Signature:</strong></p>
                  <div className="receipt-line border-b border-gray-400 mt-2 mb-4"></div>
                </div>
              </div>

              <div className="grid grid-cols-2 gap-8 mb-6">
                <div>
                  <p><strong>Name:</strong> Power Afric Sales Team</p>
                </div>
                <div>
                  <p><strong>Date:</strong> {formatDate(order.createdAt)}</p>
                </div>
              </div>

              {/* QR Code and Verification */}
              <div className="flex justify-between items-end mt-8">
                <div className="text-xs text-gray-500">
                  <p>This is a computer-generated receipt. No signature required.</p>
                  <p>For verification, scan the QR code or visit www.powerafric.ng/verify</p>
                  {installationFee > 0 && (
                    <p className="text-blue-600 mt-1">✓ Installation fee included in total</p>
                  )}
                </div>
                {qrCodeDataUrl && (
                  <div className="text-center">
                    <img src={qrCodeDataUrl} alt="QR Code" className="w-24 h-24" />
                    <p className="text-xs text-gray-500 mt-1">Scan to verify</p>
                  </div>
                )}
              </div>

              {/* Footer */}
              <div className="mt-8 text-center text-xs text-gray-500 border-t pt-4">
                <p>Thank you for choosing Power Afric Energy Services Ltd. We power your world with sustainable energy.</p>
                {installationFee > 0 && (
                  <p className="text-blue-600 mt-1">🔧 Professional installation included with your purchase</p>
                )}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  );
};

export default OrderReceipt;
