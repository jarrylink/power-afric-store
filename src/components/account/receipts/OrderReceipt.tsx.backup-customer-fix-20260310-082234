'use client';

import React, { useEffect } from 'react';
import { Order } from '@/types/auth';
import QRCode from 'qrcode';

interface OrderReceiptProps {
  order: Order;
  onClose: () => void;
}

const OrderReceipt: React.FC<OrderReceiptProps> = ({ order, onClose }) => {
  useEffect(() => {
    generateReceiptWindow();
  }, []);

  const formatDate = (date: string | Date) => {
    if (!date) return 'N/A';
    const dateObj = typeof date === 'string' ? new Date(date) : date;
    return dateObj.toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    });
  };

  const formatShortDate = (date: string | Date) => {
    if (!date) return 'N/A';
    const dateObj = typeof date === 'string' ? new Date(date) : date;
    return dateObj.toLocaleDateString('en-US', {
      year: 'numeric',
      month: '2-digit',
      day: '2-digit',
    });
  };

  const numberToWords = (num: number): string => {
    const ones = ['', 'One', 'Two', 'Three', 'Four', 'Five', 'Six', 'Seven', 'Eight', 'Nine'];
    const tens = ['', '', 'Twenty', 'Thirty', 'Forty', 'Fifty', 'Sixty', 'Seventy', 'Eighty', 'Ninety'];
    const teens = ['Ten', 'Eleven', 'Twelve', 'Thirteen', 'Fourteen', 'Fifteen', 'Sixteen', 'Seventeen', 'Eighteen', 'Nineteen'];

    const convertLessThanThousand = (n: number): string => {
      if (n === 0) return '';
      
      let result = '';
      
      if (n >= 100) {
        result += ones[Math.floor(n / 100)] + ' Hundred ';
        n %= 100;
      }
      
      if (n >= 20) {
        result += tens[Math.floor(n / 20)] + ' ';
        n %= 20;
      } else if (n >= 10) {
        result += teens[n - 10] + ' ';
        n = 0;
      }
      
      if (n > 0) {
        result += ones[n] + ' ';
      }
      
      return result;
    };

    if (num === 0) return 'Zero';

    let words = '';
    let n = Math.floor(num);
    
    if (n >= 1000000) {
      words += convertLessThanThousand(Math.floor(n / 1000000)) + 'Million ';
      n %= 1000000;
    }
    
    if (n >= 1000) {
      words += convertLessThanThousand(Math.floor(n / 1000)) + 'Thousand ';
      n %= 1000;
    }
    
    words += convertLessThanThousand(n);
    
    return words.trim() + ' Naira Only';
  };

  const generateReceiptWindow = async () => {
    // Calculate installation items and fee
    const installationItems = order.items.filter((item: any) => {
      const installationKeywords = ['inverter', 'solar panel', 'battery', 'generator', 'system', 'complete kit', 'off-grid'];
      const title = item.title?.toLowerCase() || '';
      return installationKeywords.some(keyword => title.includes(keyword));
    });
    
    const installationFee = installationItems.reduce((sum, item) => {
      return sum + (item.price * item.quantity * 0.1); // 10% installation fee
    }, 0);

    const subtotal = order.subtotal || order.total;
    const totalWithInstallation = subtotal + installationFee;

    // Generate receipt number
    const date = new Date(order.createdAt);
    const year = date.getFullYear();
    const month = String(date.getMonth() + 1).padStart(2, '0');
    const day = String(date.getDate()).padStart(2, '0');
    const random = Math.floor(Math.random() * 1000).toString().padStart(3, '0');
    const receiptNumber = `PAE/FDCR/PA-${year}${month}${day}-${random}/${year}`;

    // Generate QR Code
    let qrCodeUrl = '';
    try {
      const verificationData = {
        receiptNo: receiptNumber,
        orderId: order.id,
        date: formatShortDate(order.createdAt),
        total: totalWithInstallation,
        customer: order.shippingAddress?.fullName || order.user?.fullName || 'Walk-in Customer'
      };
      qrCodeUrl = await QRCode.toDataURL(JSON.stringify(verificationData), {
        width: 80,
        margin: 0,
        color: {
          dark: '#1a2a8a',
          light: '#FFFFFF'
        }
      });
    } catch (err) {
      console.error('Error generating QR code:', err);
    }

    // Create receipt HTML - OPTIMIZED FOR ONE PAGE WITH PRINT FIX
    const receiptHTML = `
      <!DOCTYPE html>
      <html lang="en">
      <head>
        <meta charset="UTF-8">
        <title>Power Afric Receipt - ${receiptNumber}</title>
        <script src="https://cdn.tailwindcss.com"></script>
        <style>
          @page {
            size: A4;
            margin: 0;
          }
          * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
          }
          body {
            margin: 0;
            padding: 0;
            background: #e5e7eb;
            font-family: Arial, sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
          }
          .a4 {
            width: 210mm;
            height: 297mm;
            position: relative;
            margin: 0 auto;
            background: white;
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
            overflow: hidden;
          }
          .logo-pattern {
            position: absolute;
            inset: 0;
            background-image: url("https://res.cloudinary.com/djkudkxmx/image/upload/v1762182244/logo-blue_yns0bj.png");
            background-size: 50px auto;
            background-repeat: repeat;
            opacity: 0.08;
          }
          .inner-paper-wrapper {
            position: absolute;
            width: 94%;
            height: 96%;
            top: 2%;
            left: 3%;
            border-radius: 16px;
            background: linear-gradient(to right, #07A500, #3E4095);
            padding: 6px;
          }
          .inner-paper {
            width: 100%;
            height: 100%;
            border-radius: 12px;
            background: white;
            padding: 1rem 1.2rem;
            box-sizing: border-box;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
          }
          /* ULTRA COMPACT SPACING */
          .company-header { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.2rem; }
          .company-title { font-size: 16px; font-weight: bold; color: #1a2a8a; line-height: 1.1; }
          .company-address, .company-contact { font-size: 7px; color: #4b5563; line-height: 1.1; }
          .cash-receipt-title { 
            background: linear-gradient(to right, #07A500, #3E4095); 
            color: white; 
            font-weight: bold; 
            padding: 0.1rem 0.8rem; 
            border-radius: 4px; 
            font-size: 12px;
            line-height: 1.3;
          }
          .receipt-line { border-bottom: 1px solid #9ca3af; min-height: 1rem; margin-bottom: 0.2rem; }
          .info-row { display: flex; margin-bottom: 0.1rem; font-size: 10px; }
          .info-label { font-weight: bold; width: 55px; color: #374151; }
          .info-value { color: #1f2937; }
          table { width: 100%; border-collapse: collapse; font-size: 9px; margin: 0.2rem 0; }
          th, td { border: 1px solid #d1d5db; padding: 0.15rem 0.2rem; text-align: left; }
          th { background: #f3f4f6; font-weight: 600; font-size: 8px; padding: 0.15rem; }
          .total-row { font-weight: bold; font-size: 10px; }
          .grand-total { color: #1a2a8a; font-size: 12px; }
          .amount-words { font-size: 9px; font-style: italic; margin: 0.1rem 0; }
          .checkbox-group { display: flex; gap: 0.5rem; margin: 0.1rem 0; font-size: 9px; }
          .checkbox-item { display: flex; align-items: center; gap: 0.1rem; }
          .footer { margin-top: 0.2rem; text-align: center; font-size: 6px; color: #6b7280; border-top: 1px solid #e5e7eb; padding-top: 0.2rem; }
          .qr-section { display: flex; justify-content: space-between; align-items: flex-end; margin-top: 0.2rem; }
          .compact { line-height: 1.1; }
          
          /* INSTALLATION SECTION - COMPACT */
          .installation-item { 
            background: #eff6ff; 
            padding: 0.2rem 0.5rem; 
            border-radius: 4px; 
            margin: 0.2rem 0; 
            font-size: 9px; 
            border-left: 3px solid #3e4095;
            display: flex;
            justify-content: space-between;
            align-items: center;
          }
          .installation-label {
            font-weight: bold;
            color: #1e40af;
          }
          .installation-amount {
            font-weight: bold;
            color: #1e40af;
          }
          
          /* FIX FOR PRINT - NO EXTRA SPACE */
          @media print {
            body { 
              background: white; 
              padding: 0;
              margin: 0;
              display: block;
            }
            .no-print { 
              display: none !important; 
            }
            .a4 {
              box-shadow: none;
              margin: 0;
              page-break-after: avoid;
              page-break-inside: avoid;
            }
            .inner-paper-wrapper {
              top: 2%;
              left: 3%;
            }
          }
        </style>
      </head>
      <body>
        <div class="no-print flex justify-end gap-2 mb-2 sticky top-2 z-10">
          <button onclick="window.print()" class="px-3 py-1.5 bg-[#1a2a8a] text-white rounded-lg text-xs hover:bg-[#0f1a66] shadow-lg">
            🖨️ Print Receipt
          </button>
          <button onclick="window.close()" class="px-3 py-1.5 bg-gray-500 text-white rounded-lg text-xs hover:bg-gray-600 shadow-lg">
            ✕ Close
          </button>
        </div>

        <div class="a4">
          <div class="logo-pattern"></div>
          <div class="inner-paper-wrapper">
            <div class="inner-paper compact">
              
              <!-- Company Header - ULTRA COMPACT -->
              <div class="company-header">
                <img src="https://res.cloudinary.com/djkudkxmx/image/upload/v1762182244/logo-blue_yns0bj.png" alt="Logo" class="w-12 h-auto">
                <div>
                  <div class="company-title">POWER AFRIC ENERGY SERVICES LTD</div>
                  <div class="company-address">B3&B4 Khalil Rahman Complex, GRA, Katsina</div>
                  <div class="company-contact">08033666041 • 08100360057 • sales@powerafric.ng</div>
                </div>
              </div>

              <!-- Receipt Title & Number - TIGHT -->
              <div class="flex justify-between items-center mt-0 mb-1">
                <div class="cash-receipt-title">CASH RECEIPT</div>
                <div class="font-semibold text-gray-700 text-[9px]">${receiptNumber}</div>
              </div>

              <!-- Customer Information - COMPACT with ACTUAL DATA -->
              <div class="mb-1">
                <div class="info-row">
                  <span class="info-label">Name:</span>
                  <span class="info-value">${order.shippingAddress?.fullName || order.user?.fullName || 'Walk-in Customer'}</span>
                </div>
                <div class="info-row">
                  <span class="info-label">Address:</span>
                  <span class="info-value">${order.shippingAddress ? `${order.shippingAddress.street || ''}, ${order.shippingAddress.city || ''}, ${order.shippingAddress.state || ''}` : 'N/A'}</span>
                </div>
                <div class="info-row">
                  <span class="info-label">Phone:</span>
                  <span class="info-value">${order.shippingAddress?.phone || order.user?.phone || 'N/A'}</span>
                </div>
                <div class="info-row">
                  <span class="info-label">Date:</span>
                  <span class="info-value">${formatDate(order.createdAt)}</span>
                </div>
              </div>

              <!-- Items Table - COMPACT -->
              <table>
                <thead>
                  <tr>
                    <th>Item</th>
                    <th width="30">Qty</th>
                    <th width="55">Price</th>
                    <th width="55">Total</th>
                  </tr>
                </thead>
                <tbody>
                  ${order.items.map((item: any) => {
                    const itemTotal = item.price * item.quantity;
                    return `
                      <tr>
                        <td>${item.title.length > 28 ? item.title.substring(0, 28) + '...' : item.title}</td>
                        <td class="text-center">${item.quantity}</td>
                        <td>₦${item.price.toLocaleString()}</td>
                        <td>₦${itemTotal.toLocaleString()}</td>
                      </tr>
                    `;
                  }).join('')}
                </tbody>
              </table>

              <!-- Installation as SINGLE ITEM (no product list) -->
              ${installationFee > 0 ? `
                <div class="installation-item">
                  <span class="installation-label">🔧 INSTALLATION SERVICES (10%)</span>
                  <span class="installation-amount">₦${installationFee.toLocaleString()}</span>
                </div>
              ` : ''}

              <!-- Totals - COMPACT -->
              <div class="mt-1 text-right">
                <div class="flex justify-end gap-4 text-[9px]">
                  <span class="font-bold">Subtotal:</span>
                  <span class="w-16 text-right">₦${subtotal.toLocaleString()}</span>
                </div>
                ${installationFee > 0 ? `
                  <div class="flex justify-end gap-4 text-[9px] text-blue-800">
                    <span class="font-bold">Installation:</span>
                    <span class="w-16 text-right">₦${installationFee.toLocaleString()}</span>
                  </div>
                ` : ''}
                ${order.shipping > 0 ? `
                  <div class="flex justify-end gap-4 text-[9px]">
                    <span class="font-bold">Shipping:</span>
                    <span class="w-16 text-right">₦${order.shipping.toLocaleString()}</span>
                  </div>
                ` : ''}
                ${order.tax > 0 ? `
                  <div class="flex justify-end gap-4 text-[9px]">
                    <span class="font-bold">Tax:</span>
                    <span class="w-16 text-right">₦${order.tax.toLocaleString()}</span>
                  </div>
                ` : ''}
                <div class="flex justify-end gap-4 text-[11px] font-bold border-t border-gray-300 mt-0.5 pt-0.5">
                  <span class="grand-total">TOTAL:</span>
                  <span class="grand-total w-16 text-right">₦${totalWithInstallation.toLocaleString()}</span>
                </div>
              </div>

              <!-- Amount in Words - COMPACT -->
              <div class="amount-words mt-0.5">
                <span class="font-bold">Amount:</span> ${numberToWords(totalWithInstallation)}
              </div>

              <!-- Payment Method - COMPACT -->
              <div class="mt-0.5">
                <div class="flex items-center gap-2">
                  <span class="font-bold text-[9px]">Payment:</span>
                  <div class="checkbox-group">
                    <div class="checkbox-item"><input type="checkbox" ${order.paymentMethod === 'cash' ? 'checked' : ''} disabled> Cash</div>
                    <div class="checkbox-item"><input type="checkbox" ${order.paymentMethod === 'bank_transfer' ? 'checked' : ''} disabled> Transfer</div>
                    <div class="checkbox-item"><input type="checkbox" ${order.paymentMethod === 'cheque' ? 'checked' : ''} disabled> Cheque</div>
                    <div class="checkbox-item"><input type="checkbox" ${order.paymentMethod === 'pos' ? 'checked' : ''} disabled> POS</div>
                  </div>
                </div>
              </div>

              <!-- Received By - COMPACT 2-COLUMN -->
              <div class="grid grid-cols-2 gap-3 mt-1 text-[9px]">
                <div>
                  <div class="font-bold">Received By:</div>
                  <div class="receipt-line"></div>
                  <div class="font-bold mt-0.5">Name:</div>
                  <div class="receipt-line">Power Afric Team</div>
                </div>
                <div>
                  <div class="font-bold">Authorized Signature:</div>
                  <div class="receipt-line"></div>
                  <div class="flex justify-between mt-0.5">
                    <span class="font-bold">Date:</span>
                    <span>${formatShortDate(order.createdAt)}</span>
                  </div>
                </div>
              </div>

              <!-- QR Code and Footer - COMPACT -->
              <div class="qr-section mt-0.5">
                <div class="text-[6px] text-gray-500">
                  <div>Computer-generated receipt</div>
                  <div>www.powerafric.ng/verify</div>
                  ${installationFee > 0 ? '<div class="text-blue-600">✓ Installation included</div>' : ''}
                </div>
                ${qrCodeUrl ? `
                  <div class="text-center">
                    <img src="${qrCodeUrl}" alt="QR" class="w-14 h-14" />
                    <div class="text-[5px] text-gray-500 -mt-1">Scan</div>
                  </div>
                ` : ''}
              </div>

              <!-- Footer -->
              <div class="footer">
                Thank you for choosing Power Afric Energy Services Ltd.
              </div>
            </div>
          </div>
        </div>

        <script>
          // Ensure print dialog shows properly
          document.addEventListener('DOMContentLoaded', function() {
            // Fix for any browser rendering issues
            document.body.style.display = 'flex';
            document.body.style.flexDirection = 'column';
            document.body.style.alignItems = 'center';
            document.body.style.justifyContent = 'center';
          });
        </script>
      </body>
      </html>
    `;

    // Open in new window with exact dimensions
    const receiptWindow = window.open('', '_blank', 'width=900,height=700,scrollbars=yes');
    if (receiptWindow) {
      receiptWindow.document.write(receiptHTML);
      receiptWindow.document.close();
      receiptWindow.focus();
      
      // Additional fix for print positioning
      setTimeout(() => {
        if (receiptWindow.document) {
          const style = receiptWindow.document.createElement('style');
          style.innerHTML = `
            @media print {
              body { 
                display: block !important; 
                padding: 0 !important;
                margin: 0 !important;
              }
              .no-print { display: none !important; }
              .a4 { 
                page-break-after: avoid; 
                page-break-inside: avoid;
                box-shadow: none;
              }
            }
          `;
          receiptWindow.document.head.appendChild(style);
        }
      }, 100);
    } else {
      alert('Please allow pop-ups to view the receipt');
    }

    onClose();
  };

  // Loading state
  return (
    <div className="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/50 backdrop-blur-sm">
      <div className="bg-white rounded-2xl shadow-2xl p-5 max-w-sm text-center">
        <div className="animate-spin rounded-full h-8 w-8 border-b-2 border-[#1a2a8a] mx-auto mb-2"></div>
        <h3 className="text-base font-bold text-gray-900 mb-1">Opening Receipt</h3>
        <p className="text-xs text-gray-600 mb-2">Please allow pop-ups...</p>
        <button onClick={onClose} className="px-3 py-1.5 bg-gray-500 text-white rounded-lg text-xs">
          Cancel
        </button>
      </div>
    </div>
  );
};

export default OrderReceipt;
