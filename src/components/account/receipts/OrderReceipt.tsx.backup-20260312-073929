  </style>
</head>
<body>
  <div class="no-print">
    <button class="print-btn" onclick="window.print()">🖨️ Print Receipt</button>
    <button class="close-btn" onclick="window.close()">✕ Close</button>
  </div>

  <div class="receipt">
    <div class="pattern"></div>
    <div class="border-wrapper">
      <div class="content">
