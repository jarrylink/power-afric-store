      color: #4b5563;
    }
    .footer {
      margin-top: 30px;
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
    }
    .signature {
      flex: 1;
    }
    .signature-line {
      border-bottom: 1px solid #9ca3af;
      width: 200px;
      margin: 10px 0;
    }
    .qr-code {
      text-align: center;
    }
    .qr-code img {
      width: 100px;
      height: 100px;
    }
    .qr-code p {
      font-size: 9px;
      color: #6b7280;
      margin-top: 5px;
    }
    .no-print {
      display: flex;
      justify-content: flex-end;
      gap: 10px;
      margin-bottom: 15px;
    }
    .no-print button {
      padding: 10px 20px;
      border: none;
      border-radius: 8px;
      font-size: 14px;
      cursor: pointer;
      transition: all 0.3s;
    }
    .print-btn {
      background: #1a2a8a;
      color: white;
    }
    .print-btn:hover {
