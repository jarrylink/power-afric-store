          <div class="company-info">
            <h1>POWER AFRIC ENERGY SERVICES LTD</h1>
            <p>No. B3 & B4 Khalil Rahman Shopping Complex, GRA. Katsina State - Nigeria.</p>
            <p>08033666041 • 08100360057 • sales@powerafric.ng • www.powerafric.ng</p>
          </div>
        </div>

        <!-- Title -->
        <div class="title-section">
          <div class="receipt-title">CASH RECEIPT</div>
          <div class="receipt-number">Receipt No.: ${receiptNumber}</div>
        </div>

        <!-- Customer Info -->
        <div class="info-grid">
          <div class="info-item">
            <strong>Customer Information</strong>
            <p><strong>Name:</strong> ${customerName}</p>
            <p><strong>Phone:</strong> ${customerPhone}</p>
            <p><strong>Email:</strong> ${customerEmail}</p>
          </div>
          <div class="info-item">
            <strong>Delivery Address</strong>
            <p>${address}</p>
            <p><strong>Date:</strong> ${formatDate(order.createdAt)}</p>
          </div>
        </div>

        <!-- Items Table -->
        <table>
          <thead>
            <tr>
              <th>Item</th>
              <th width="60">Qty</th>
              <th width="100">Unit Price</th>
              <th width="100">Total</th>
            </tr>
          </thead>
          <tbody>
            ${order.items.map((item: any) => {
              const isInstallation = installationItems.some(i => i.id === item.id);
              const itemTotal = item.price * item.quantity;
              return `
                <tr${isInstallation ? ' class="service-row"' : ''}>
                  <td>${item.title}${isInstallation ? ' <small>(Installation)</small>' : ''}</td>
                  <td>${item.quantity}</td>
                  <td>₦${item.price.toLocaleString()}</td>
                  <td>₦${itemTotal.toLocaleString()}</td>
                </tr>
              `;
            }).join('')}
            ${installationFee > 0 ? `
              <tr class="service-row">
                <td colspan="3" style="text-align: right; font-weight: bold;">Installation Services (10%):</td>
                <td>₦${installationFee.toLocaleString()}</td>
              </tr>
            ` : ''}
          </tbody>
        </table>

        <!-- Totals -->
        <div class="totals">
          <div class="total-line">
            <span>Subtotal:</span>
            <span>₦${subtotal.toLocaleString()}</span>
          </div>
          ${installationFee > 0 ? `
            <div class="total-line">
              <span>Installation Fee:</span>
              <span>₦${installationFee.toLocaleString()}</span>
            </div>
          ` : ''}
          <div class="total-line grand-total">
            <span>GRAND TOTAL:</span>
            <span>₦${totalWithInstallation.toLocaleString()}</span>
          </div>
        </div>

        <!-- Amount in Words -->
        <div class="amount-words">
          <strong>Amount in Words:</strong> ${numberToWords(totalWithInstallation)}
        </div>

        <!-- Payment Method -->
        <div class="payment-method">
          <strong>Payment Method:</strong>
          <div class="checkbox-group">
            <label class="checkbox-item">
              <input type="checkbox" ${order.paymentMethod === 'cash' ? 'checked' : ''} disabled> Cash
            </label>
            <label class="checkbox-item">
              <input type="checkbox" ${order.paymentMethod === 'bank_transfer' ? 'checked' : ''} disabled> Transfer
            </label>
            <label class="checkbox-item">
              <input type="checkbox" ${order.paymentMethod === 'cheque' ? 'checked' : ''} disabled> Cheque
            </label>
            <label class="checkbox-item">
              <input type="checkbox" ${order.paymentMethod === 'pos' ? 'checked' : ''} disabled> POS
            </label>
          </div>
        </div>

        <!-- Footer with Signature and QR -->
        <div class="footer">
          <div class="signature">
            <div><strong>Received By:</strong></div>
            <div class="signature-line"></div>
            <div style="margin-top: 15px;"><strong>Authorized Signature:</strong></div>
            <div class="signature-line"></div>
            <div style="margin-top: 10px;">
              <span><strong>Date:</strong> ${formatShortDate(order.createdAt)}</span>
            </div>
          </div>
          ${qrCodeUrl ? `
            <div class="qr-code">
              <img src="${qrCodeUrl}" alt="QR Code">
              <p>Scan to verify</p>
            </div>
          ` : ''}
        </div>

        <!-- Footer Note -->
        <div style="text-align: center; margin-top: 20px; font-size: 9px; color: #9ca3af;">
          <p>This is a computer-generated receipt. No signature required.</p>
          <p>Thank you for choosing Power Afric Energy Services Ltd.</p>
        </div>
      </div>
