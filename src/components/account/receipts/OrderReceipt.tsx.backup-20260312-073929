    }
    .payment-method {
      margin: 20px 0;
      padding: 15px;
      background: #f9fafb;
      border-radius: 8px;
      display: flex;
      align-items: center;
      gap: 20px;
    }
    .checkbox-group {
      display: flex;
      gap: 20px;
    }
    .checkbox-item {
      display: flex;
      align-items: center;
      gap: 5px;
