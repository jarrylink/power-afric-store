      border-radius: 16px;
      padding: 30px;
      position: relative;
      z-index: 1;
      overflow-y: auto;
    }
    .header {
      display: flex;
      align-items: center;
      gap: 20px;
      margin-bottom: 30px;
      border-bottom: 2px solid #e5e7eb;
      padding-bottom: 20px;
    }
    .logo {
      width: 80px;
      height: auto;
    }
