'use client';

import React, { useEffect } from 'react';
import { Order } from '@/types/auth';
import QRCode from 'qrcode';

interface OrderReceiptProps {
  order: Order;
  onClose: () => void;
}

const OrderReceipt: React.FC<OrderReceiptProps> = ({ order, onClose }) => {
  useEffect(() => {
    generateReceiptWindow();
  }, []);

  const formatDate = (date: string | Date) => {
    if (!date) return 'N/A';
    const dateObj = typeof date === 'string' ? new Date(date) : date;
    return dateObj.toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    });
  };

  const formatShortDate = (date: string | Date) => {
    if (!date) return 'N/A';
    const dateObj = typeof date === 'string' ? new Date(date) : date;
    return dateObj.toLocaleDateString('en-US', {
      year: 'numeric',
      month: '2-digit',
      day: '2-digit',
    });
  };

  const numberToWords = (num: number): string => {
    const ones = ['', 'One', 'Two', 'Three', 'Four', 'Five', 'Six', 'Seven', 'Eight', 'Nine'];
    const tens = ['', '', 'Twenty', 'Thirty', 'Forty', 'Fifty', 'Sixty', 'Seventy', 'Eighty', 'Ninety'];
    const teens = ['Ten', 'Eleven', 'Twelve', 'Thirteen', 'Fourteen', 'Fifteen', 'Sixteen', 'Seventeen', 'Eighteen', 'Nineteen'];

    const convertLessThanThousand = (n: number): string => {
      if (n === 0) return '';
      
      let result = '';
      
      if (n >= 100) {
        result += ones[Math.floor(n / 100)] + ' Hundred ';
        n %= 100;
      }
      
      if (n >= 20) {
        result += tens[Math.floor(n / 20)] + ' ';
        n %= 20;
      } else if (n >= 10) {
        result += teens[n - 10] + ' ';
        n = 0;
      }
      
      if (n > 0) {
        result += ones[n] + ' ';
      }
      
      return result;
    };

    if (num === 0) return 'Zero';

    let words = '';
    let n = Math.floor(num);
    
    if (n >= 1000000) {
      words += convertLessThanThousand(Math.floor(n / 1000000)) + 'Million ';
      n %= 1000000;
    }
    
    if (n >= 1000) {
      words += convertLessThanThousand(Math.floor(n / 1000)) + 'Thousand ';
      n %= 1000;
    }
    
    words += convertLessThanThousand(n);
    
    return words.trim() + ' Naira Only';
  };

  const generateReceiptWindow = async () => {
    // Calculate installation items and fee
    const installationItems = order.items.filter((item: any) => {
      const installationKeywords = ['inverter', 'solar panel', 'battery', 'generator', 'system', 'complete kit', 'off-grid'];
      const title = item.title?.toLowerCase() || '';
      return installationKeywords.some(keyword => title.includes(keyword));
    });
    
    const installationFee = installationItems.reduce((sum, item) => {
      return sum + (item.price * item.quantity * 0.1); // 10% installation fee
    }, 0);

    const subtotal = order.subtotal || order.total;
    const totalWithInstallation = subtotal + installationFee;

    // Generate receipt number
    const date = new Date(order.createdAt);
    const year = date.getFullYear();
    const month = String(date.getMonth() + 1).padStart(2, '0');
    const day = String(date.getDate()).padStart(2, '0');
    const random = Math.floor(Math.random() * 1000).toString().padStart(3, '0');
    const receiptNumber = `PAE/FDCR/PA-${year}${month}${day}-${random}/${year}`;

    // Generate QR Code
    let qrCodeUrl = '';
    try {
      const verificationData = {
        receiptNo: receiptNumber,
        orderId: order.id,
        date: formatShortDate(order.createdAt),
        total: totalWithInstallation,
        customer: order.shippingAddress?.fullName || order.user?.fullName || 'Walk-in Customer'
      };
      qrCodeUrl = await QRCode.toDataURL(JSON.stringify(verificationData), {
        width: 90,
        margin: 0,
        color: {
          dark: '#1a2a8a',
          light: '#FFFFFF'
        }
      });
    } catch (err) {
      console.error('Error generating QR code:', err);
    }

    // Create receipt HTML - OPTIMIZED FOR ONE PAGE
    const receiptHTML = `
      <!DOCTYPE html>
      <html lang="en">
      <head>
        <meta charset="UTF-8">
        <title>Power Afric Receipt - ${receiptNumber}</title>
        <script src="https://cdn.tailwindcss.com"></script>
        <style>
          @page {
            size: A4;
            margin: 0;
          }
          body {
            margin: 0;
            background: #e5e7eb;
            padding: 10px;
            font-family: Arial, sans-serif;
          }
          .a4 {
            width: 210mm;
            min-height: 297mm;
            position: relative;
            margin: 0 auto;
            background: white;
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
            overflow: hidden;
          }
          .logo-pattern {
            position: absolute;
            inset: 0;
            background-image: url("https://res.cloudinary.com/djkudkxmx/image/upload/v1762182244/logo-blue_yns0bj.png");
            background-size: 50px auto;
            background-repeat: repeat;
            opacity: 0.08;
          }
          .inner-paper-wrapper {
            position: absolute;
            width: 92%;
            height: 96%;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            border-radius: 16px;
            background: linear-gradient(to right, #07A500, #3E4095);
            padding: 8px;
          }
          .inner-paper {
            width: 100%;
            height: 100%;
            border-radius: 12px;
            background: rgba(255, 255, 255, 0.97);
            padding: 1.2rem 1.5rem;
            box-sizing: border-box;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
          }
          /* TIGHT SPACING */
          .company-header { display: flex; align-items: center; gap: 0.8rem; margin-bottom: 0.5rem; }
          .company-title { font-size: 18px; font-weight: bold; color: #1a2a8a; line-height: 1.2; }
          .company-address, .company-contact { font-size: 8px; color: #4b5563; line-height: 1.2; }
          .cash-receipt-title { 
            background: linear-gradient(to right, #07A500, #3E4095); 
            color: white; 
            font-weight: bold; 
            padding: 0.2rem 1rem; 
            border-radius: 4px; 
            font-size: 14px;
          }
          .receipt-line { border-bottom: 1px solid #9ca3af; min-height: 1.2rem; margin-bottom: 0.3rem; }
          .info-row { display: flex; margin-bottom: 0.2rem; font-size: 11px; }
          .info-label { font-weight: bold; width: 70px; color: #374151; }
          .info-value { color: #1f2937; }
          table { width: 100%; border-collapse: collapse; font-size: 10px; margin: 0.3rem 0; }
          th, td { border: 1px solid #d1d5db; padding: 0.2rem 0.3rem; text-align: left; }
          th { background: #f3f4f6; font-weight: 600; font-size: 9px; padding: 0.2rem; }
          .installation-badge { 
            background: #dbeafe; 
            color: #1e40af; 
            font-size: 7px; 
            padding: 0.1rem 0.3rem; 
            border-radius: 10px; 
            margin-left: 0.3rem;
            white-space: nowrap;
          }
          .installation-row { background: #eff6ff; }
          .total-row { font-weight: bold; font-size: 11px; }
          .grand-total { color: #1a2a8a; font-size: 13px; }
          .amount-words { font-size: 10px; font-style: italic; margin: 0.2rem 0; }
          .checkbox-group { display: flex; gap: 0.8rem; margin: 0.2rem 0; font-size: 10px; }
          .checkbox-item { display: flex; align-items: center; gap: 0.2rem; }
          .footer { margin-top: 0.5rem; text-align: center; font-size: 7px; color: #6b7280; border-top: 1px solid #e5e7eb; padding-top: 0.3rem; }
          .qr-section { display: flex; justify-content: space-between; align-items: flex-end; margin-top: 0.3rem; }
          .compact { line-height: 1.2; }
          .installation-summary { 
            background: #eff6ff; 
            padding: 0.4rem 0.8rem; 
            border-radius: 4px; 
            margin: 0.3rem 0; 
            font-size: 9px; 
            border-left: 3px solid #3e4095;
          }
          .installation-summary p { margin: 0.1rem 0; }
          .installation-summary ul { margin: 0.1rem 0 0.1rem 1.2rem; }
          @media print {
            body { background: white; padding: 0; }
            .no-print { display: none; }
          }
        </style>
      </head>
      <body>
        <div class="no-print flex justify-end gap-2 mb-2 sticky top-2 z-10">
          <button onclick="window.print()" class="px-4 py-2 bg-[#1a2a8a] text-white rounded-lg text-sm hover:bg-[#0f1a66] shadow-lg">
            🖨️ Print
          </button>
          <button onclick="window.close()" class="px-4 py-2 bg-gray-500 text-white rounded-lg text-sm hover:bg-gray-600 shadow-lg">
            ✕ Close
          </button>
        </div>

        <div class="a4">
          <div class="logo-pattern"></div>
          <div class="inner-paper-wrapper">
            <div class="inner-paper compact">
              
              <!-- Company Header - TIGHT -->
              <div class="company-header">
                <img src="https://res.cloudinary.com/djkudkxmx/image/upload/v1762182244/logo-blue_yns0bj.png" alt="Logo" class="w-14 h-auto">
                <div>
                  <div class="company-title">POWER AFRIC ENERGY SERVICES LTD</div>
                  <div class="company-address">No. B3 & B4 Khalil Rahman Complex, GRA, Katsina - Nigeria.</div>
                  <div class="company-contact">08033666041 • 08100360057 • sales@powerafric.ng</div>
                </div>
              </div>

              <!-- Receipt Title & Number - TIGHT -->
              <div class="flex justify-between items-center mt-1 mb-2">
                <div class="cash-receipt-title">CASH RECEIPT</div>
                <div class="font-semibold text-gray-700 text-xs">${receiptNumber}</div>
              </div>

              <!-- Customer Information - COMPACT with ACTUAL DATA -->
              <div class="mb-2">
                <div class="info-row">
                  <span class="info-label">Name:</span>
                  <span class="info-value">${order.shippingAddress?.fullName || order.user?.fullName || 'Walk-in Customer'}</span>
                </div>
                <div class="info-row">
                  <span class="info-label">Address:</span>
                  <span class="info-value">${order.shippingAddress ? `${order.shippingAddress.street || ''}, ${order.shippingAddress.city || ''}, ${order.shippingAddress.state || ''}` : 'N/A'}</span>
                </div>
                <div class="info-row">
                  <span class="info-label">Phone:</span>
                  <span class="info-value">${order.shippingAddress?.phone || order.user?.phone || 'N/A'}</span>
                </div>
                <div class="info-row">
                  <span class="info-label">Date:</span>
                  <span class="info-value">${formatDate(order.createdAt)}</span>
                </div>
              </div>

              <!-- Items Table - COMPACT -->
              <table>
                <thead>
                  <tr>
                    <th>Item</th>
                    <th width="35">Qty</th>
                    <th width="60">Price</th>
                    <th width="55">Total</th>
                  </tr>
                </thead>
                <tbody>
                  ${order.items.map((item: any) => {
                    const needsInstallation = installationItems.some(i => i.id === item.id);
                    const itemTotal = item.price * item.quantity;
                    return `
                      <tr ${needsInstallation ? 'class="installation-row"' : ''}>
                        <td>
                          ${item.title.length > 30 ? item.title.substring(0, 30) + '...' : item.title}
                          ${needsInstallation ? '<span class="installation-badge">Install</span>' : ''}
                        </td>
                        <td class="text-center">${item.quantity}</td>
                        <td>₦${item.price.toLocaleString()}</td>
                        <td>₦${itemTotal.toLocaleString()}</td>
                      </tr>
                    `;
                  }).join('')}
                </tbody>
              </table>

              <!-- Installation as SEPARATE ITEM at the bottom -->
              ${installationFee > 0 ? `
                <div class="installation-summary">
                  <div class="flex justify-between items-center font-bold text-blue-800">
                    <span>🔧 INSTALLATION SERVICES (10%):</span>
                    <span>₦${installationFee.toLocaleString()}</span>
                  </div>
                  <ul class="text-gray-700">
                    ${installationItems.map(item => `
                      <li>• ${item.title} (Qty: ${item.quantity}) - ₦${(item.price * item.quantity * 0.1).toLocaleString()}</li>
                    `).join('')}
                  </ul>
                  <p class="text-gray-600 mt-1"><small>Scheduled within 3-5 business days</small></p>
                </div>
              ` : ''}

              <!-- Totals - COMPACT -->
              <div class="mt-1 text-right">
                <div class="flex justify-end gap-4 text-xs">
                  <span class="font-bold">Subtotal:</span>
                  <span class="w-20 text-right">₦${subtotal.toLocaleString()}</span>
                </div>
                ${installationFee > 0 ? `
                  <div class="flex justify-end gap-4 text-xs text-blue-800">
                    <span class="font-bold">Installation:</span>
                    <span class="w-20 text-right">₦${installationFee.toLocaleString()}</span>
                  </div>
                ` : ''}
                ${order.shipping > 0 ? `
                  <div class="flex justify-end gap-4 text-xs">
                    <span class="font-bold">Shipping:</span>
                    <span class="w-20 text-right">₦${order.shipping.toLocaleString()}</span>
                  </div>
                ` : ''}
                ${order.tax > 0 ? `
                  <div class="flex justify-end gap-4 text-xs">
                    <span class="font-bold">Tax:</span>
                    <span class="w-20 text-right">₦${order.tax.toLocaleString()}</span>
                  </div>
                ` : ''}
                <div class="flex justify-end gap-4 text-sm font-bold border-t border-gray-300 mt-1 pt-1">
                  <span class="grand-total">GRAND TOTAL:</span>
                  <span class="grand-total w-20 text-right">₦${totalWithInstallation.toLocaleString()}</span>
                </div>
              </div>

              <!-- Amount in Words - COMPACT -->
              <div class="amount-words mt-1">
                <span class="font-bold">Amount:</span> ${numberToWords(totalWithInstallation)}
              </div>

              <!-- Payment Method - COMPACT -->
              <div class="mt-1">
                <div class="flex items-center gap-2">
                  <span class="font-bold text-xs">Payment:</span>
                  <div class="checkbox-group">
                    <div class="checkbox-item"><input type="checkbox" ${order.paymentMethod === 'cash' ? 'checked' : ''} disabled> Cash</div>
                    <div class="checkbox-item"><input type="checkbox" ${order.paymentMethod === 'bank_transfer' ? 'checked' : ''} disabled> Transfer</div>
                    <div class="checkbox-item"><input type="checkbox" ${order.paymentMethod === 'cheque' ? 'checked' : ''} disabled> Cheque</div>
                    <div class="checkbox-item"><input type="checkbox" ${order.paymentMethod === 'pos' ? 'checked' : ''} disabled> POS</div>
                  </div>
                </div>
              </div>

              <!-- Received By - COMPACT 2-COLUMN -->
              <div class="grid grid-cols-2 gap-4 mt-2 text-xs">
                <div>
                  <div class="font-bold">Received By:</div>
                  <div class="receipt-line"></div>
                  <div class="font-bold mt-1">Name:</div>
                  <div class="receipt-line">Power Afric Team</div>
                </div>
                <div>
                  <div class="font-bold">Authorized Signature:</div>
                  <div class="receipt-line"></div>
                  <div class="flex justify-between mt-1">
                    <span class="font-bold">Date:</span>
                    <span>${formatShortDate(order.createdAt)}</span>
                  </div>
                </div>
              </div>

              <!-- QR Code and Footer - COMPACT -->
              <div class="qr-section">
                <div class="text-[7px] text-gray-500">
                  <div>Computer-generated receipt</div>
                  <div>Verify: www.powerafric.ng/verify</div>
                  ${installationFee > 0 ? '<div class="text-blue-600">✓ Installation included</div>' : ''}
                </div>
                ${qrCodeUrl ? `
                  <div class="text-center">
                    <img src="${qrCodeUrl}" alt="QR" class="w-16 h-16" />
                    <div class="text-[6px] text-gray-500 -mt-1">Scan</div>
                  </div>
                ` : ''}
              </div>

              <!-- Footer -->
              <div class="footer">
                Thank you for choosing Power Afric Energy Services Ltd.
              </div>
            </div>
          </div>
        </div>
      </body>
      </html>
    `;

    // Open in new window
    const receiptWindow = window.open('', '_blank', 'width=900,height=700,scrollbars=yes');
    if (receiptWindow) {
      receiptWindow.document.write(receiptHTML);
      receiptWindow.document.close();
      receiptWindow.focus();
    } else {
      alert('Please allow pop-ups to view the receipt');
    }

    onClose();
  };

  // Loading state
  return (
    <div className="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/50 backdrop-blur-sm">
      <div className="bg-white rounded-2xl shadow-2xl p-6 max-w-md text-center">
        <div className="animate-spin rounded-full h-10 w-10 border-b-2 border-[#1a2a8a] mx-auto mb-3"></div>
        <h3 className="text-lg font-bold text-gray-900 mb-1">Opening Receipt</h3>
        <p className="text-sm text-gray-600 mb-3">Please allow pop-ups...</p>
        <button onClick={onClose} className="px-4 py-2 bg-gray-500 text-white rounded-lg text-sm">
          Cancel
        </button>
      </div>
    </div>
  );
};

export default OrderReceipt;
